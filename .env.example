APP_NAME=RedisOps Playground
APP_ENV=development
LOG_LEVEL=INFO
REDIS_URL=redis://redis:6379/0
JOB_QUEUE_KEY=queue:jobs:pending
JOB_PROCESSING_KEY=queue:jobs:processing
JOB_INDEX_KEY=jobs:index
JOB_EVENTS_STREAM_KEY=events:jobs
JOB_EVENTS_MAX_LENGTH=1000
FIXED_RATE_LIMIT=5
FIXED_RATE_WINDOW_SECONDS=60
SLIDING_RATE_LIMIT=5
SLIDING_RATE_WINDOW_SECONDS=60
CACHE_DEMO_KEY=cache:analytics:summary
CACHE_TTL_SECONDS=30
CACHE_DEMO_DELAY_SECONDS=0.2
SESSION_TTL_SECONDS=1800
SESSION_ROLLING_EXPIRATION=true
JOB_TTL_SECONDS=86400
WORKER_POLL_TIMEOUT_SECONDS=5
WORKER_JOB_DELAY_SECONDS=2
